<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d3" for="edge" attr.name="ev_count" attr.type="long" />
  <key id="d2" for="edge" attr.name="predicate" attr.type="string" />
  <key id="d1" for="node" attr.name="node_type" attr.type="string" />
  <key id="d0" for="node" attr.name="cui" attr.type="string" />
  <graph edgedefault="directed">
    <node id="Injury">
      <data key="d0">C0175677</data>
      <data key="d1">regular</data>
    </node>
