      <data key="d0">C0020538</data>
      <data key="d1">exposure</data>
    </node>
    <edge source="Injury" target="Alzheimers">
      <data key="d2">CAUSES</data>
      <data key="d3">19</data>
    </edge>
    <edge source="Injury" target="Hypertension">
      <data key="d2">CAUSES</data>
      <data key="d3">35</data>
    </edge>
    <edge source="Nitric_Oxide" target="Alzheimers">
